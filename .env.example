# Copy to .env and fill in values

# Anthropic API key — required for haiku/sonnet tiers
ANTHROPIC_API_KEY=your_key_here

# MODEL_TIER controls which LLM backend is used across all nodes
# Options: mock | ollama | haiku | sonnet
# mock   — hardcoded responses, $0, tests graph/state/streaming
# ollama — llama3.2:3b via local Ollama, $0, tests SSE pipe + UI rendering
# haiku  — claude-haiku-4-5-20251001, ~$0.01/session, quality tuning
# sonnet — full sonnet+extended thinking, ~$0.10/session, final polish
MODEL_TIER=mock

# Ollama base URL (only needed for MODEL_TIER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Frontend dev server (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
